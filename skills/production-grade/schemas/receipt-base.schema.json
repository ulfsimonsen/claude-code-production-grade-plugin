{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "receipt-base.schema.json",
  "title": "Base Receipt Schema",
  "description": "All task receipts extend this base schema.",
  "type": "object",
  "required": ["task_id", "skill", "status", "completed_at", "artifacts", "metrics", "effort"],
  "properties": {
    "task_id": {
      "type": "string",
      "description": "Task identifier, e.g. T1, T3a"
    },
    "skill": {
      "type": "string",
      "description": "Skill that produced this receipt, e.g. product-manager"
    },
    "status": {
      "type": "string",
      "enum": ["completed", "failed", "skipped"],
      "description": "Final status of the task"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp of completion"
    },
    "artifacts": {
      "type": "array",
      "items": { "type": "string" },
      "description": "File paths produced by this task"
    },
    "metrics": {
      "type": "object",
      "description": "Task-specific metrics"
    },
    "effort": {
      "type": "object",
      "required": ["files_read", "files_written", "tool_calls"],
      "properties": {
        "files_read": { "type": "integer" },
        "files_written": { "type": "integer" },
        "tool_calls": { "type": "integer" }
      }
    }
  }
}
