{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "worktree": {
    "sparsePaths": [
      "services/",
      "frontend/",
      "libs/",
      "api/",
      "schemas/",
      "docs/",
      "tests/",
      "infrastructure/",
      ".github/",
      "Claude-Production-Grade-Suite/",
      ".production-grade.yaml",
      "CLAUDE.md",
      "package.json",
      "pyproject.toml",
      "go.mod",
      "Cargo.toml",
      "tsconfig.json",
      "docker-compose.yml",
      "Dockerfile*"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "excludedCommands": ["docker"],
    "filesystem": {
      "allowWrite": [
        "//tmp/claude",
        "//private/tmp/claude"
      ],
      "denyRead": [
        "~/.ssh",
        "~/.aws/credentials",
        "~/.gnupg"
      ],
      "denyWrite": [
        "~/.ssh",
        "~/.aws",
        "~/.gnupg",
        "~/.bashrc",
        "~/.zshrc",
        "~/.bash_profile",
        "~/.zprofile",
        "//etc",
        "//usr"
      ]
    },
    "network": {
      "allowedHosts": [
        "*",
        "github.com",
        "api.github.com",
        "raw.githubusercontent.com",
        "objects.githubusercontent.com",
        "registry.npmjs.org",
        "context7.com",
        "api.context7.com"
      ]
    }
  },
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "ExitPlanMode",
      "NotebookEdit",
      "Skill",
      "WebFetch",
      "WebSearch",
      "Bash(docker compose *)",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_context7_context7__query-docs"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -f *)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)",
      "Bash(chown *)",
      "Bash(dd *)",
      "Bash(mkfs*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(~/.ssh/**)"
    ]
  }
}
